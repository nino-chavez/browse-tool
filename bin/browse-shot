#!/usr/bin/env node
import { mkdirSync } from "node:fs";
import { tmpdir } from "node:os";
import { join, dirname, resolve } from "node:path";
import { connect, activeOrFirstPage, parseArgs } from "../lib/connect.js";

const args = parseArgs(process.argv.slice(2), { full: "bool", wait: "bool" });
let url = args._[0];

if (!url) {
  console.error("Usage: browse-shot <url> [--out path.png] [--full] [--wait] [--wait-ms <n>] [--wait-for <selector>]");
  process.exit(1);
}

if (!/^[a-z][a-z0-9+.-]*:/i.test(url)) {
  url = `https://${url}`;
}

const out = args.out
  ? resolve(args.out)
  : join(tmpdir(), `browse-tool-shot-${Date.now()}.png`);

mkdirSync(dirname(out), { recursive: true });

const browser = await connect();
const page = await activeOrFirstPage(browser);

try {
  // Navigate to URL with readiness wait
  await page.goto(url, {
    waitUntil: args.wait ? "networkidle2" : "domcontentloaded",
    timeout: 30000,
  });

  // Wait for selector if provided
  if (args["wait-for"]) {
    const selector = args["wait-for"];
    await page.waitForSelector(selector, { timeout: 10000 });
  }

  // Wait additional time if provided
  if (args["wait-ms"]) {
    const ms = parseInt(args["wait-ms"], 10);
    if (!isNaN(ms) && ms > 0) {
      await new Promise(resolve => setTimeout(resolve, ms));
    }
  }

  // Take screenshot
  await page.screenshot({ path: out, fullPage: !!args.full, type: "png" });
  console.log(out);
} catch (err) {
  console.error(`browse-shot failed: ${err.message}`);
  process.exitCode = 1;
} finally {
  browser.disconnect();
}
